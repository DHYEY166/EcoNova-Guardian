# AWS (use temporary credentials export or IAM keys)
# For temporary: aws configure export-credentials --format env
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1
# Use inference profile (required for Converse). Example: us.amazon.nova-lite-v1:0
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0

# Optional: agent thresholds (0–1)
CONF_HIGH=0.85
CONF_MED=0.7

# Optional: cap Bedrock calls per day (0 = no cap)
BEDROCK_DAILY_CAP=0
